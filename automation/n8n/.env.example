N8N_IMAGE=docker.n8n.io/n8nio/n8n:2.26.8
N8N_PORT=5678
N8N_TIMEZONE=America/Mexico_City
# Generate locally with scripts/configure_automation_token.sh. Never commit the real value.
PAWSEAR_AUTOMATION_TOKEN=
# Required only when activating Telegram or another external webhook.
N8N_WEBHOOK_URL=https://your-public-webhook.example/
